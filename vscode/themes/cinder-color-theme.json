  "tokenColors": [
    {
      "name": "Comments — Smoke, italic",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#8B8378", "fontStyle": "italic" }
    },
    {
      "name": "Doc comments — upright (API surface, not asides)",
      "scope": ["comment.block.documentation", "comment.block.documentation punctuation"],
      "settings": { "foreground": "#8B8378", "fontStyle": "" }
    },
    {
      "name": "Doc tags (@param, @returns) — Sandstone, one step up from the doc body",
      "scope": [
        "comment.block.documentation storage.type.class",
        "comment.block.documentation punctuation.definition.block.tag",
        "comment.block.documentation keyword.other.documentation",
        "storage.type.class.jsdoc",
        "punctuation.definition.block.tag.jsdoc"
      ],
      "settings": { "foreground": "#ABA399", "fontStyle": "" }
    },
    {
      "name": "Doc tag payloads (types, names) stay in the doc voice",
      "scope": [
        "comment.block.documentation entity.name.type.instance",
        "comment.block.documentation variable.other",
        "entity.name.type.instance.jsdoc",
        "variable.other.jsdoc"
      ],
      "settings": { "foreground": "#8B8378", "fontStyle": "" }
    },
    {
      "name": "TODO / FIXME codetags — Brass bold, must survive a skim",
      "scope": ["keyword.codetag", "comment keyword.codetag.notation"],
      "settings": { "foreground": "#CBA32D", "fontStyle": "bold" }
    },
    {
      "name": "Keywords & storage — Coral",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "storage",
        "storage.type",
        "variable.language",
        "constant.language.import-export-all"
      ],
      "settings": { "foreground": "#EC8F68" }
    },
    {
      "name": "Storage modifiers — Coral italic",
      "scope": ["storage.modifier"],
      "settings": { "foreground": "#EC8F68", "fontStyle": "italic" }
    },
    {
      "name": "Operators — Sandstone",
      "scope": [
        "keyword.operator",
        "keyword.operator.logical",
        "keyword.operator.arithmetic",
        "keyword.operator.assignment",
        "keyword.operator.comparison"
      ],
      "settings": { "foreground": "#ABA399" }
    },
    {
      "name": "Arrow => reads as an operator, not storage",
      "scope": ["storage.type.function.arrow"],
      "settings": { "foreground": "#ABA399", "fontStyle": "" }
    },
    {
      "name": "Ternary / expression keywords stay Coral",
      "scope": ["keyword.operator.new", "keyword.operator.expression", "keyword.operator.delete", "keyword.operator.typeof", "keyword.operator.instanceof"],
      "settings": { "foreground": "#EC8F68" }
    },
    {
      "name": "Punctuation & delimiters — Smoke",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": { "foreground": "#8B8378" }
    },
    {
      "name": "Functions & methods — Antique Gold",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function",
        "meta.function-call.generic.python",
        "meta.method-call entity.name.function",
        "source.powershell support.function"
      ],
      "settings": { "foreground": "#DFBC59" }
    },
    {
      "name": "Decorators & annotations — Brass italic",
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator entity.name.function",
        "meta.decorator punctuation.decorator",
        "storage.type.annotation",
        "punctuation.definition.annotation",
        "meta.annotation.identifier"
      ],
      "settings": { "foreground": "#CBA32D", "fontStyle": "italic" }
    },
    {
      "name": "Types, classes, enums — Steel",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.class",
        "support.type",
        "entity.name.type.enum",
        "storage.type.primitive",
        "keyword.type"
      ],
      "settings": { "foreground": "#92A9C2" }
    },
    {
      "name": "Interfaces — Steel italic",
      "scope": ["entity.name.type.interface"],
      "settings": { "foreground": "#92A9C2", "fontStyle": "italic" }
    },
    {
      "name": "Namespaces & modules — Gunmetal",
      "scope": [
        "entity.name.type.namespace",
        "entity.name.type.module",
        "entity.name.namespace",
        "entity.name.package",
        "storage.modifier.package",
        "storage.modifier.import"
      ],
      "settings": { "foreground": "#6E8CAB" }
    },
    {
      "name": "Variables & properties — Parchment (prose, uncolored)",
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.property",
        "variable.other.object",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": { "foreground": "#EAE4DB" }
    },
    {
      "name": "Parameters — Parchment italic",
      "scope": ["variable.parameter", "meta.function.parameters variable"],
      "settings": { "foreground": "#EAE4DB", "fontStyle": "italic" }
    },
    {
      "name": "Constants, numbers, booleans, enum members — Heather",
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "variable.other.constant",
        "variable.other.enummember",
        "support.constant",
        "keyword.other.unit"
      ],
      "settings": { "foreground": "#BE97B8" }
    },
    {
      "name": "Strings — Patina",
      "scope": ["string", "string.quoted", "string.template", "punctuation.definition.string"],
      "settings": { "foreground": "#7DB5A0" }
    },
    {
      "name": "String escapes & template expressions — Glow",
      "scope": [
        "constant.character.escape",
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "punctuation.section.embedded",
        "constant.other.placeholder"
      ],
      "settings": { "foreground": "#F3B69C" }
    },
    {
      "name": "Regex — Copper Oxide",
      "scope": ["string.regexp"],
      "settings": { "foreground": "#579A82" }
    },
    {
      "name": "Regex quantifiers & anchors",
      "scope": [
        "keyword.operator.quantifier.regexp",
        "keyword.control.anchor.regexp"
      ],
      "settings": { "foreground": "#EC8F68" }
    },
    {
      "name": "Regex character classes — Heather",
      "scope": ["constant.other.character-class.regexp", "constant.other.character-class.set.regexp"],
      "settings": { "foreground": "#BE97B8" }
    },
    {
      "name": "Regex groups — Brass",
      "scope": ["punctuation.definition.group.regexp"],
      "settings": { "foreground": "#CBA32D" }
    },
    {
      "name": "Invalid — Garnet",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#E58177" }
    },
    {
      "name": "Deprecated — Smoke strikethrough",
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#8B8378", "fontStyle": "strikethrough" }
    },

    {
      "name": "HTML/JSX tags — Coral",
      "scope": ["entity.name.tag", "support.class.component"],
      "settings": { "foreground": "#EC8F68" }
    },
    {
      "name": "Tag punctuation — Smoke",
      "scope": ["punctuation.definition.tag"],
      "settings": { "foreground": "#8B8378" }
    },
    {
      "name": "HTML attributes — Brass italic",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#CBA32D", "fontStyle": "italic" }
    },
    {
      "name": "HTML entities — Glow",
      "scope": ["constant.character.entity"],
      "settings": { "foreground": "#F3B69C" }
    },

    {
      "name": "CSS class selectors — Antique Gold",
      "scope": [
        "entity.other.attribute-name.class.css",
        "source.css entity.name.tag"
      ],
      "settings": { "foreground": "#DFBC59", "fontStyle": "" }
    },
    {
      "name": "CSS id selectors — Coral",
      "scope": ["entity.other.attribute-name.id.css"],
      "settings": { "foreground": "#EC8F68", "fontStyle": "" }
    },
    {
      "name": "CSS pseudo — Coral italic",
      "scope": [
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": { "foreground": "#EC8F68", "fontStyle": "italic" }
    },
    {
      "name": "CSS property names — Steel",
      "scope": ["support.type.property-name.css", "support.type.vendored.property-name.css"],
      "settings": { "foreground": "#92A9C2" }
    },
    {
      "name": "CSS values — Parchment",
      "scope": ["support.constant.property-value.css", "meta.property-value.css"],
      "settings": { "foreground": "#EAE4DB" }
    },
    {
      "name": "CSS units & numbers — Heather",
      "scope": ["keyword.other.unit.css", "constant.numeric.css"],
      "settings": { "foreground": "#BE97B8" }
    },
    {
      "name": "CSS at-rules — Coral",
      "scope": ["keyword.control.at-rule", "punctuation.definition.keyword.css"],
      "settings": { "foreground": "#EC8F68" }
    },
    {
      "name": "CSS !important — Garnet bold",
      "scope": ["keyword.other.important.css"],
      "settings": { "foreground": "#E58177", "fontStyle": "bold" }
    },

    {
      "name": "JSON keys — Steel",
      "scope": ["support.type.property-name.json", "source.json meta.structure.dictionary.json support.type.property-name.json"],
      "settings": { "foreground": "#92A9C2" }
    },
    {
      "name": "YAML keys — Steel",
      "scope": ["entity.name.tag.yaml"],
      "settings": { "foreground": "#92A9C2" }
    },
    {
      "name": "YAML anchors & aliases — Heather",
      "scope": ["entity.name.type.anchor.yaml", "variable.other.alias.yaml"],
      "settings": { "foreground": "#BE97B8" }
    },
    {
      "name": "YAML tags — Coral",
      "scope": ["storage.type.tag-handle.yaml"],
      "settings": { "foreground": "#EC8F68" }
    },

    {
      "name": "Markdown headings — Antique Gold bold",
      "scope": ["markup.heading", "markup.heading entity.name", "punctuation.definition.heading.markdown"],
      "settings": { "foreground": "#DFBC59", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#EAE4DB", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#EAE4DB", "fontStyle": "italic" }
    },
    {
      "name": "Markdown link text — Steel underline",
      "scope": ["string.other.link.title.markdown", "string.other.link.description.markdown"],
      "settings": { "foreground": "#92A9C2", "fontStyle": "underline" }
    },
    {
      "name": "Markdown link URL — Gunmetal",
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#6E8CAB" }
    },
    {
      "name": "Markdown inline code — Glow",
      "scope": ["markup.inline.raw", "punctuation.definition.raw.markdown"],
      "settings": { "foreground": "#F3B69C" }
    },
    {
      "name": "Markdown code blocks — Sand",
      "scope": ["markup.fenced_code.block.markdown", "markup.raw.block.markdown"],
      "settings": { "foreground": "#CFC8BD" }
    },
    {
      "name": "Markdown blockquote — Smoke italic",
      "scope": ["markup.quote", "punctuation.definition.quote.begin.markdown"],
      "settings": { "foreground": "#8B8378", "fontStyle": "italic" }
    },
    {
      "name": "Markdown list markers — Ember",
      "scope": ["punctuation.definition.list.begin.markdown"],
      "settings": { "foreground": "#E26A38" }
    },
    {
      "name": "Markdown separators — Iron",
      "scope": ["meta.separator.markdown"],
      "settings": { "foreground": "#524C44" }
    },

    {
      "name": "SQL keywords — Coral",
      "scope": ["keyword.other.DML.sql", "keyword.other.data-integrity.sql", "keyword.other.sql"],
      "settings": { "foreground": "#EC8F68" }
    },
    {
      "name": "SQL functions — Antique Gold",
      "scope": ["support.function.aggregate.sql", "support.function.scalar.sql"],
      "settings": { "foreground": "#DFBC59" }
    },

    {
      "name": "Shell builtins — Coral",
      "scope": ["support.function.builtin.shell", "keyword.control.shell"],
      "settings": { "foreground": "#EC8F68" }
    },
    {
      "name": "Shell variables & interpolation — Glow",
      "scope": [
        "variable.other.normal.shell",
        "punctuation.definition.variable.shell",
        "variable.other.special.shell",
        "variable.parameter.positional.shell",
        "string.interpolated.dollar.shell"
      ],
      "settings": { "foreground": "#F3B69C" }
    },
    {
      "name": "Shell flags — Sandstone",
      "scope": ["constant.other.option.shell", "constant.other.option.dash.shell"],
