    },
    {
      "name": "Log output — debug",
      "scope": ["token.debug-token"],
      "settings": { "foreground": "#BE97B8" }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#6E8CAB",
    "class": "#92A9C2",
    "class.declaration": "#92A9C2",
    "interface": { "foreground": "#92A9C2", "italic": true },
    "enum": "#92A9C2",
    "enumMember": "#BE97B8",
    "struct": "#92A9C2",
    "type": "#92A9C2",
    "typeParameter": { "foreground": "#92A9C2", "italic": true },
    "function": "#DFBC59",
    "method": "#DFBC59",
    "decorator": { "foreground": "#CBA32D", "italic": true },
    "macro": "#CBA32D",
    "variable": "#EAE4DB",
    "variable.readonly": "#BE97B8",
    "parameter": { "foreground": "#EAE4DB", "italic": true },
    "property": "#EAE4DB",
    "property.readonly": "#BE97B8",
    "string": "#7DB5A0",
    "number": "#BE97B8",
    "regexp": "#579A82",
    "keyword": "#EC8F68",
    "modifier": { "foreground": "#EC8F68", "italic": true },
    "selfParameter": "#EC8F68",
    "clsParameter": "#EC8F68",
    "event": "#DFBC59",
    "operator": "#ABA399",
    "comment": { "foreground": "#8B8378", "italic": true },
    "*.deprecated": { "strikethrough": true },
    "*.static": { "italic": true }
  }
